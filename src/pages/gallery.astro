---
import BaseLayout from "../layouts/BaseLayout.astro";
import logo from "../images/logo2.png";
import "../styles/index.css";

const imageModules = import.meta.glob('/src/images/gallery/**/*', { eager: true });

const galleries: Record<string, { src: string; alt: string }[]> = {};
for (const [path, mod] of Object.entries(imageModules)) {
  const parts = path.split('/');
  const galleryId = parts[parts.length - 2];
  const fileName = parts[parts.length - 1].replace(/\.[^.]+$/, '');
  if (!galleries[galleryId]) galleries[galleryId] = [];
  galleries[galleryId].push({ src: (mod as any).default.src, alt: fileName });
}
---

<BaseLayout title="Galeria — Omnibus Media Studio">

  <!-- ========== THIN HEADER ========== -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-primary-light">
    <div class="max-w-7xl mx-auto px-6 h-[50px] flex items-center justify-between">

      <!-- Back arrow -->
      <a
        href="/#portfolio"
        aria-label="Wróć do portfolio"
        class="flex items-center gap-2 text-white/60 hover:text-accent transition-colors duration-300 group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="font-body text-[10px] tracking-[0.25em] uppercase">Powrót</span>
      </a>

      <!-- Logo -->
      <a href="/" class="absolute left-1/2 -translate-x-1/2">
        <img src={logo.src} alt="Omnibus Media Studio" class="h-7 w-auto object-contain" />
      </a>

      <!-- Gallery title placeholder (filled by JS) -->
      <span id="gallery-title" class="font-body text-[10px] tracking-[0.25em] uppercase text-white/40"></span>

    </div>
    <!-- bottom rule -->
    <div class="h-px bg-white/10"></div>
  </header>

  <!-- ========== GALLERY CONTENT ========== -->
  <main class="pt-[50px] min-h-screen bg-primary">

    <!-- not-found state (hidden by default, shown by JS if id is invalid) -->
    <div id="gallery-not-found" class="hidden flex flex-col items-center justify-center h-[80vh] gap-4">
      <p class="font-body text-xs tracking-[0.3em] uppercase text-white/30">Nie znaleziono galerii</p>
      <a href="/#portfolio" class="font-body text-[10px] tracking-[0.25em] uppercase text-accent hover:text-accent-light transition-colors duration-300">← Wróć do portfolio</a>
    </div>

    <!-- Section header -->
    <div id="gallery-header" class="flex items-center gap-4 px-8 py-16 max-w-7xl mx-auto opacity-0 transition-opacity duration-500">
      <div class="h-px bg-white/20 w-12 shrink-0"></div>
      <span id="gallery-heading" class="font-body text-xs tracking-[0.3em] uppercase text-white whitespace-nowrap pl-2"></span>
      <div class="h-px bg-white/20 flex-1"></div>
    </div>

    <!-- Masonry grid -->
    <div
      id="gallery-grid"
      class="px-6 pb-24 max-w-7xl mx-auto"
      style="columns: 3; column-gap: 12px;"
    >
    </div>

  </main>

  <!-- ========== LIGHTBOX ========== -->
  <div
    id="lightbox"
    class="fixed inset-0 z-[100] bg-primary/95 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
    aria-hidden="true"
  >
    <!-- Close -->
    <button
      id="lb-close"
      aria-label="Zamknij"
      class="absolute top-6 right-6 text-white/50 hover:text-white transition-colors duration-300"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Prev -->
    <button
      id="lb-prev"
      aria-label="Poprzednie zdjęcie"
      class="absolute left-4 md:left-8 text-white/50 hover:text-white transition-colors duration-300"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <!-- Image -->
    <img
      id="lb-img"
      src=""
      alt=""
      class="max-h-[90vh] max-w-[90vw] object-contain select-none"
    />

    <!-- Next -->
    <button
      id="lb-next"
      aria-label="Następne zdjęcie"
      class="absolute right-4 md:right-8 text-white/50 hover:text-white transition-colors duration-300"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Counter -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2">
      <span id="lb-counter" class="font-body text-[10px] tracking-[0.3em] uppercase text-white/30"></span>
    </div>
  </div>

</BaseLayout>

<style is:global>
  #gallery-grid img {
    break-inside: avoid;
    display: block;
    width: 100%;
    margin-bottom: 12px;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }
  #gallery-grid img:hover {
    opacity: 0.75;
  }

  @media (max-width: 768px) {
    #gallery-grid { columns: 2 !important; }
  }
  @media (max-width: 480px) {
    #gallery-grid { columns: 1 !important; }
  }
</style>

<script define:vars={{ galleries }} is:inline>
  const params = new URLSearchParams(window.location.search);
  const id = params.get('id') ?? '';
  const images = galleries[id] ?? [];

  const titleEl    = document.getElementById('gallery-title');
  const headingEl  = document.getElementById('gallery-heading');
  const headerEl   = document.getElementById('gallery-header');
  const gridEl     = document.getElementById('gallery-grid');
  const notFoundEl = document.getElementById('gallery-not-found');

  if (!images.length) {
    notFoundEl.classList.remove('hidden');
    notFoundEl.classList.add('flex');
  } else {
    titleEl.textContent  = id;
    headingEl.textContent = id;
    headerEl.style.opacity = '1';

    images.forEach((img, i) => {
      const el = document.createElement('img');
      el.src = img.src;
      el.alt = img.alt;
      el.loading = 'lazy';
      el.addEventListener('click', () => openLightbox(i));
      gridEl.appendChild(el);
    });
  }

  // ── Lightbox ──────────────────────────────────────────
  const lightbox = document.getElementById('lightbox');
  const lbImg    = document.getElementById('lb-img');
  const lbClose  = document.getElementById('lb-close');
  const lbPrev   = document.getElementById('lb-prev');
  const lbNext   = document.getElementById('lb-next');
  const lbCounter = document.getElementById('lb-counter');
  let lbIndex = 0;

  function openLightbox(i) {
    lbIndex = i;
    renderLightbox();
    lightbox.style.opacity = '1';
    lightbox.style.pointerEvents = 'auto';
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.style.opacity = '0';
    lightbox.style.pointerEvents = 'none';
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function renderLightbox() {
    const img = images[lbIndex];
    lbImg.src = img.src;
    lbImg.alt = img.alt;
    lbCounter.textContent = `${lbIndex + 1} / ${images.length}`;
  }

  function prevImage() {
    lbIndex = ((lbIndex - 1) + images.length) % images.length;
    renderLightbox();
  }

  function nextImage() {
    lbIndex = (lbIndex + 1) % images.length;
    renderLightbox();
  }

  lbClose.addEventListener('click', closeLightbox);
  lbPrev.addEventListener('click', prevImage);
  lbNext.addEventListener('click', nextImage);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (lightbox.getAttribute('aria-hidden') === 'true') return;
    if (e.key === 'Escape')      closeLightbox();
    if (e.key === 'ArrowLeft')   prevImage();
    if (e.key === 'ArrowRight')  nextImage();
  });
</script>
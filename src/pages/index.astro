---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import landingImg from "../images/landing_page.jpg";
import logo from "../images/logo2.png";
import iconFB from "../images/socials/FB.png";
import iconInsta from "../images/socials/Insta.png";
import iconTiktok from "../images/socials/tiktok.png";
import iconYoutube from "../images/socials/youtube.png";

import Oferta from '../components/sections/Oferta.astro';
import Portfolio from '../components/sections/Portfolio.astro';
import ONas from '../components/sections/ONas.astro';

import "../styles/index.css";
import Opinie from "../components/sections/Opinie.astro";
import Kontakt from "../components/sections/Kontakt.astro";
---

<BaseLayout title="Omnibus Media Studio">
<div class="overflow-x-hidden">
  <!-- ========== HEADER ========== -->
  <header
    id="header"
    class="fixed top-0 left-0 right-0 z-50 w-screen"
  >
    <div
      class="max-w-7xl mx-auto px-8 h-[70px] flex items-center justify-between"
    >
      <a href="/">
        <img
          src={logo.src}
          alt="Omnibus Media Studio"
          class="h-10 w-auto object-contain"
        />
      </a>
      <!-- Nav -->
      <nav class="hidden md:flex items-center gap-10">
        <a
          href="#oferta"
          class="font-body text-xs tracking-[0.2em] uppercase text-white/70 hover:text-accent transition-colors duration-300"
          >Oferta</a
        >
        <a
          href="#portfolio"
          class="font-body text-xs tracking-[0.2em] uppercase text-white/70 hover:text-accent transition-colors duration-300"
          >Portfolio</a
        >
        <a
          href="#o-nas"
          class="font-body text-xs tracking-[0.2em] uppercase text-white/70 hover:text-accent transition-colors duration-300"
          >O nas</a
        >
        <a
          href="#opinie"
          class="font-body text-xs tracking-[0.2em] uppercase text-white/70 hover:text-accent transition-colors duration-300"
          >Opinie</a
        >
        <a
          href="#kontakt"
          class="font-body text-xs tracking-[0.2em] uppercase text-white/70 hover:text-accent transition-colors duration-300"
          >Kontakt</a
        >
      </nav>

      <!-- Social icons -->
      <div class="flex items-center gap-4">
        <div class="hidden md:flex items-center gap-4">
        <a
          href="https://www.facebook.com/profile.php?id=61551022192369"
          aria-label="Facebook"
          target="_blank"
          rel="noopener noreferrer"
          class="opacity-50 hover:opacity-100 transition-opacity duration-300"
        >
          <img src={iconFB.src} alt="Facebook" class="w-[30px] h-[30px] object-contain" />
        </a>
        <a
          href="https://www.instagram.com/omnibusmediastudio/"
          aria-label="Instagram"
          target="_blank"
          rel="noopener noreferrer"
          class="opacity-50 hover:opacity-100 transition-opacity duration-300"
        >
          <img
            src={iconInsta.src}
            alt="Instagram"
            class="w-[30px] h-[30px] object-contain"
          />
        </a>
        <a
          href="https://www.tiktok.com/@omnibusmediastudio"
          aria-label="TikTok"
          target="_blank"
          rel="noopener noreferrer"
          class="opacity-50 hover:opacity-100 transition-opacity duration-300"
        >
          <img
            src={iconTiktok.src}
            alt="TikTok"
            class="w-[30px] h-[30px] object-contain"
          />
        </a>
        <a
          href="https://www.youtube.com/@OmnibusMediaStudio"
          aria-label="YouTube"
          target="_blank"
          rel="noopener noreferrer"
          class="opacity-50 hover:opacity-100 transition-opacity duration-300"
        >
          <img
            src={iconYoutube.src}
            alt="YouTube"
            class="w-[30px] h-[30px] object-contain"
          />
        </a>
        </div>

        <!-- Hamburger button — visible only below md -->
        <button
          id="menu-toggle"
          aria-label="Otwórz menu"
          aria-expanded="false"
          class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-[6px] ml-15"
        >
          <span class="line-top block w-6 h-[1.5px] bg-white"></span>
          <span class="line-mid block w-6 h-[1.5px] bg-white"></span>
          <span class="line-bot block w-6 h-[1.5px] bg-white"></span>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 flex flex-col bg-primary/95 backdrop-blur-sm translate-x-full transition-transform duration-300 ease-in-out md:hidden"
    aria-hidden="true"
  >
    <!-- Close button -->
    <div class="flex justify-end px-8 pt-6 pb-4">
      <button
        id="menu-close"
        aria-label="Zamknij menu"
        class="text-white/70 hover:text-accent transition-colors duration-300 p-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Menu links -->
    <nav class="flex flex-col items-center justify-center flex-1 gap-10">
      <a href="#oferta" class="mobile-nav-link font-body text-sm tracking-[0.3em] uppercase text-white/70 hover:text-accent transition-colors duration-300">Oferta</a>
      <a href="#portfolio" class="mobile-nav-link font-body text-sm tracking-[0.3em] uppercase text-white/70 hover:text-accent transition-colors duration-300">Portfolio</a>
      <a href="#o-nas" class="mobile-nav-link font-body text-sm tracking-[0.3em] uppercase text-white/70 hover:text-accent transition-colors duration-300">O nas</a>
      <a href="#opinie" class="mobile-nav-link font-body text-sm tracking-[0.3em] uppercase text-white/70 hover:text-accent transition-colors duration-300">Opinie</a>
      <a href="#kontakt" class="mobile-nav-link font-body text-sm tracking-[0.3em] uppercase text-white/70 hover:text-accent transition-colors duration-300">Kontakt</a>
    </nav>
  </div>

  <style>
    #menu-toggle .line-top    { transition: transform 0.3s ease; }
    #menu-toggle .line-mid    { transition: opacity 0.2s ease; }
    #menu-toggle .line-bot    { transition: transform 0.3s ease; }

    #menu-toggle.is-open .line-top { transform: translateY(7.5px) rotate(45deg); }
    #menu-toggle.is-open .line-mid { opacity: 0; }
    #menu-toggle.is-open .line-bot { transform: translateY(-7.5px) rotate(-45deg); }

    #header {
      transition: background-color 0.4s ease, backdrop-filter 0.4s ease;
    }
    #header.scrolled {
      background-color: rgba(51, 50, 48, 0.95);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
  </style>

  <script>
    const toggle = document.getElementById('menu-toggle')!;
    const closeBtn = document.getElementById('menu-close')!;
    const menu = document.getElementById('mobile-menu')!;

    function openMenu() {
      menu.classList.remove('translate-x-full');
      menu.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menu.classList.add('translate-x-full');
      menu.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', () => {
      toggle.classList.contains('is-open') ? closeMenu() : openMenu();
    });
    closeBtn.addEventListener('click', closeMenu);

    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    const header = document.getElementById('header')!;
    function updateHeader() {
      header.classList.toggle('scrolled', window.scrollY > 20);
    }
    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();
  </script>

  <!-- ========== HERO / LANDING ========== -->
  <section class="relative w-full h-screen overflow-hidden">
    <!-- Background image -->
    <Image
      src={landingImg}
      alt="Omnibus Media Studio - sesja fotograficzna"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />

    <!-- Dark overlay with subtle gradient -->
    <div
      class="absolute inset-0 bg-gradient-to-b from-primary/85 via-primary/65 to-primary/90"
    >
    </div>

    <!-- Centered text -->
    <div
      class="relative z-10 flex flex-col items-center justify-center h-full px-6 text-center"
    >
      <div class="overflow-hidden">
        <p
          class="font-body text-xs tracking-[0.35em] uppercase text-accent mb-6 animate-fade-in-up hero-tagline"
        >
          Fotografia &amp; Film
        </p>
      </div>
      <div class="overflow-hidden">
        <h1
          class="font-display text-4xl md:text-6xl lg:text-7xl font-light text-white leading-tight max-w-4xl animate-fade-in-up hero-heading"
        >
          Obrazy, które mówią <br />
          więcej niż słowa
        </h1>
      </div>
      <div class="overflow-hidden mt-4">
        <p
          class="font-body text-sm tracking-[0.2em] uppercase text-white/50 animate-fade-in-up hero-subtitle"
        >
          Omnibus Media Studio
        </p>
      </div>
    </div>

    <!-- Scroll arrow -->
    <div
      class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-bounce-slow"
    >
      <span class="font-body text-[10px] tracking-[0.3em] uppercase text-white/40 pl-[0.3em]">
        Przewiń
      </span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-accent"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
        ></path>
      </svg>
    </div>
  </section>

  <!-- Section divider -->
  <Oferta />
  <Portfolio />
  <ONas />
  <Opinie />
  <Kontakt />

</div>
</BaseLayout>


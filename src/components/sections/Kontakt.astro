---
import logo from "../../images/logo1.png";
import iconFB from "../../images/socials/FB.png";
import iconInsta from "../../images/socials/Insta.png";
import iconTiktok from "../../images/socials/tiktok.png";
import iconYoutube from "../../images/socials/youtube.png";
---

<footer id="kontakt" class="bg-primary-light flex items-center px-6 sm:px-12 lg:px-[150px] py-10 lg:py-0 lg:min-h-[250px]">
  <div class="flex flex-col lg:flex-row items-center w-full gap-10 lg:gap-[150px]">

    <!-- Contact subsection -->
    <div class="flex flex-col gap-2 items-center lg:items-start">
      <h2 class="font-display text-2xl font-light text-white tracking-[0.2em] uppercase mb-1">Kontakt</h2>
      <a href="tel:+48515149256" class="font-body text-sm text-white/70 hover:text-white transition-colors duration-300 lg:pointer-events-none lg:cursor-default">515 149 256 - Franek</a>
      <a href="tel:+48882308213" class="font-body text-sm text-white/70 hover:text-white transition-colors duration-300 lg:pointer-events-none lg:cursor-default">882 308 213 - Dominik</a>

      <p class="font-body text-sm text-white/70">omnibusmediastudio@gmail.com</p>
      <div class="flex items-center gap-3 mt-2">
        <a href="https://www.facebook.com/profile.php?id=61551022192369" aria-label="Facebook" target="_blank" rel="noopener noreferrer" class="opacity-50 hover:opacity-100 transition-opacity duration-300">
          <img src={iconFB.src} alt="Facebook" class="w-[30px] h-[30px] object-contain" />
        </a>
        <a href="https://www.instagram.com/omnibusmediastudio/" aria-label="Instagram" target="_blank" rel="noopener noreferrer" class="opacity-50 hover:opacity-100 transition-opacity duration-300">
          <img src={iconInsta.src} alt="Instagram" class="w-[30px] h-[30px] object-contain" />
        </a>
        <a href="https://www.tiktok.com/@omnibusmediastudio" aria-label="TikTok" target="_blank" rel="noopener noreferrer" class="opacity-50 hover:opacity-100 transition-opacity duration-300">
          <img src={iconTiktok.src} alt="TikTok" class="w-[30px] h-[30px] object-contain" />
        </a>
        <a href="https://www.youtube.com/@OmnibusMediaStudio" aria-label="YouTube" target="_blank" rel="noopener noreferrer" class="opacity-50 hover:opacity-100 transition-opacity duration-300">
          <img src={iconYoutube.src} alt="YouTube" class="w-[30px] h-[30px] object-contain" />
        </a>
      </div>
    </div>

    <!-- Button -->
    <a
      href="https://mail.google.com/mail/?view=cm&to=adres.email@gmail.com"
      target="_blank"
      rel="noopener noreferrer"
      class="bg-accent text-white font-body text-xs tracking-[0.2em] uppercase px-8 py-4 hover:bg-accent-light transition-colors duration-300 shrink-0"
    >
      Napisz do nas
    </a>

    <!-- Spacer -->
    <div class="hidden lg:block flex-1"></div>

    <!-- Logo -->
    <img src={logo.src} alt="Omnibus Media Studio" class="h-24 w-auto object-contain" />

  </div>
</footer>